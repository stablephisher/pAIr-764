rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════
    //  DEVELOPMENT MODE — All authenticated users can read/write
    //  TODO: Tighten rules for production
    // ════════════════════════════════════════════════════════════

    match /users/{userId} {
      // Authenticated users can read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollections under users
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Policies — read for all authenticated users
    match /policies/{policyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allow writes for demo
    }

    // Global stats — read for all authenticated
    match /global_stats/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allow writes for demo
    }
    
    // Analyses collection at root level (in case used)
    match /analyses/{analysisId} {
      allow read, write: if request.auth != null;
    }

    // ════════════════════════════════════════════════════════════
    //  FALLBACK — Allow authenticated users for demo
    // ════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
