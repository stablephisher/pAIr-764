# pAIr v5 — Backend Environment Variables
# Copy this file to .env and fill in your values

# === AI Configuration (REQUIRED) ===
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
PRIMARY_MODEL=google/gemini-2.0-flash-exp:free
FALLBACK_MODEL=google/gemma-3-27b-it:free

# === Gemini API Key (for embeddings & profile enrichment) ===
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here

# === Firebase (optional — falls back to local JSON storage) ===
# FIREBASE_PROJECT_ID=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# === Policy Discovery ===
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here
DISCOVERY_ENABLED=TRUE
DISCOVERY_INTERVAL_HOURS=6

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
DEMO_MODE=FALSE
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://pair-msme.vercel.app
LOG_LEVEL=INFO
SITE_URL=https://pair-msme.vercel.app
